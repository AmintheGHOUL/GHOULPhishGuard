{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0.0",
  "description": "Analyzes emails for phishing indicators with plain-English explanations. Includes full header parsing for SPF, DKIM, and DMARC.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:*/*",
    "https://*.replit.app/*",
    "https://*.replit.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
